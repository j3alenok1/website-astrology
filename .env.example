# Database (Vercel: добавьте DATABASE_URL в Environment Variables)
DATABASE_URL="postgresql://user:password@localhost:5432/astro_consult?schema=public"

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-change-in-production

# Admin Credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password

# reCAPTCHA
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# Dev-only: отключить reCAPTCHA локально (НЕ включать в продакшне)
DISABLE_RECAPTCHA=true

# Dev-only (client): если true, форма не будет требовать reCAPTCHA
NEXT_PUBLIC_DISABLE_RECAPTCHA=true

# Email (SMTP) — заявки приходят на mari.makk80@gmail.com
# Для Gmail: НЕ обычный пароль! Нужен пароль приложения:
# 1. Включите 2FA: https://myaccount.google.com/security
# 2. Создайте пароль: https://myaccount.google.com/apppasswords
# 3. Вставьте 16-символьный пароль (без пробелов)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=mari.makk80@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=mari.makk80@gmail.com
SMTP_TO=mari.makk80@gmail.com

# Telegram — дублирование заявок (создайте бота у @BotFather, добавьте бота в канал как админа)
TELEGRAM_BOT_TOKEN=
# Публичный канал: @имя_канала или числовой id (например -1001234567890)
TELEGRAM_CHAT_ID=

# Google Sheets Integration (optional)
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
GOOGLE_SHEETS_SPREADSHEET_ID=

# Analytics
NEXT_PUBLIC_YANDEX_METRIKA_ID=
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# CRM Webhook (optional)
CRM_WEBHOOK_URL=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe — основной вариант: Payment Link (Vercel → STRIPE_PAYMENT_LINK обязателен для редиректа на оплату)
STRIPE_PAYMENT_LINK=https://buy.stripe.com/test_xxx
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=https://buy.stripe.com/test_xxx
# Опционально: только если НЕ используете ссылку выше — встроенная Buy Button (иначе не нужно)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# NEXT_PUBLIC_STRIPE_BUY_BUTTON_ID=buy_btn_xxx
# Опционально: отдельная ссылка для консультаций (другая цена в Stripe). Иначе = ссылка календаря
# NEXT_PUBLIC_STRIPE_PAYMENT_LINK_BOOKING=https://buy.stripe.com/test_yyy
# Stripe — секреты (сервер)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ЮKassa — отключена в коде; не нужна
# YOOKASSA_SHOP_ID=
# YOOKASSA_SECRET_KEY=

# Kaspi Pay (ApiPay) — отключено; оставлено для истории / локальных тестов
# APIPAY_API_KEY=
# APIPAY_WEBHOOK_SECRET=
